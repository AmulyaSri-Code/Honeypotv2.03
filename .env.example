# Honeypot runtime secrets and deployment settings
# Recommended: run `python setup.py` to generate .env with safe credentials.
# Manual fallback: copy this file to .env and change every value before exposing the platform.

HONEYPOT_ADMIN_USER=admin
HONEYPOT_ADMIN_PASS=replace_with_a_long_unique_password
HONEYPOT_AUTH_SECRET=replace_with_output_of_python_secrets_token_urlsafe_48
HONEYPOT_TOKEN_TTL_SECONDS=28800
HONEYPOT_RATE_LIMIT_PER_MIN=240
HONEYPOT_TRUSTED_PROXIES=127.0.0.1
HONEYPOT_MAX_CAPTURE_CHARS=2048
HONEYPOT_SOCKET_TIMEOUT_SECONDS=60
HONEYPOT_MAX_CONNECTIONS_PER_SERVICE=100
HONEYPOT_MAX_CONNECTIONS_PER_IP=10
HONEYPOT_ENRICHMENT_ENABLED=true
HONEYPOT_ENRICHMENT_PROVIDER=ip-api
HONEYPOT_ENRICHMENT_TIMEOUT_SECONDS=4

# Optional outbound alert delivery. Keep secrets in .env only; do not commit real values.
HONEYPOT_ALERTS_ENABLED=false
HONEYPOT_ALERT_MIN_SEVERITY=high
HONEYPOT_ALERT_MIN_INTERVAL_SECONDS=10
SLACK_WEBHOOK_URL=
N8N_WEBHOOK_URL=
# Used by the optional docker-compose automation profile for n8n credential encryption.
N8N_ENCRYPTION_KEY=replace_with_a_32_plus_character_secret
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard/API bind host. Use 127.0.0.1 behind a reverse proxy; use 0.0.0.0 only inside isolated containers.
HONEYPOT_BIND_HOST=127.0.0.1
HONEYPOT_DASHBOARD_PORT=5050
# Public HTTPS origin used in robots.txt and sitemap.xml for crawler discovery.
HONEYPOT_PUBLIC_URL=https://your-domain.example

# Optional Flask environment marker. Do not enable debug on internet-exposed systems.
FLASK_ENV=production
